# Dependencies
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# Runtime environment and secrets
.env
.env.*
!.env.example
config/nhanchilltv.env
/etc/

# Runtime database and user-generated data
NhanChillLinuxBuild/app/backend/db/*.json
!NhanChillLinuxBuild/app/backend/db/*.example.json
NhanChillLinuxBuild/app/temp/**
!NhanChillLinuxBuild/app/temp/.gitkeep
!NhanChillLinuxBuild/app/temp/hls_temp/.gitkeep
!NhanChillLinuxBuild/app/temp/event_temp/.gitkeep

# Local IPTV playlists. Keep only examples in git.
NhanChillLinuxBuild/app/m3u_iptv/*.m3u
!NhanChillLinuxBuild/app/m3u_iptv/*.example.m3u

# Logs and caches
*.log
logs/
tmp/
temp/
.cache/
.DS_Store
Thumbs.db

# Editors
.idea/
.vscode/
*.swp
*.swo

# OS/binary artifacts from the Windows build
*.exe
*.dll
*.bat

# Windows nginx build artifacts
nginx/html/
nginx/logs/
nginx/temp/
nginx/conf/*.conf
nginx/PHP/
nginx/*.bat
nginx/*.txt
nginx/*.exe

# FFmpeg binaries
ffmpeg-core/bin/