---
import Layout from '../layouts/Layout.astro';
import MainLayout from '../components/MainLayout.jsx';
import HomeEvents from '../components/HomeEvents.jsx';
---

<Layout title="Sự kiện - NhanChillTV">
  <MainLayout client:load>
    <main class="mx-auto mt-8 w-full max-w-[1600px] px-4 pb-10 pt-6 md:px-8">
      <h1 class="text-3xl font-black text-white">Sự kiện trực tiếp</h1>
      <p class="mb-6 mt-2 text-sm text-white/55">Các chương trình đang phát và lịch sự kiện sắp tới.</p>
      <HomeEvents client:only="react" showEmpty={true} />
    </main>
  </MainLayout>
</Layout>
