rtmp {
    server {
        listen 1935;
        chunk_size 4096;

        application live {
            live on;
            record off;
            hls on;
            hls_nested on;
            hls_cleanup off;
            hls_fragment 3s;
            hls_playlist_length 30s;
            hls_path __APP_DIR__/temp/hls_temp;
        }
    }
}
