[Unit]
Description=NhanChillTV Home Agent
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
WorkingDirectory=/opt/nhanchill-home-agent
EnvironmentFile=/etc/nhanchill-home-agent.env
ExecStart=/usr/bin/python3 /opt/nhanchill-home-agent/home_agent.py
Restart=always
RestartSec=15
User=root
NoNewPrivileges=true

[Install]
WantedBy=multi-user.target
