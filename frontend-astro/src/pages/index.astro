---
import Layout from '../layouts/Layout.astro';
import MainLayout from '../components/MainLayout.jsx';
import HeroBanner from '../components/HeroBanner.jsx';
import WorldCupTodayWidget from '../components/WorldCupTodayWidget.jsx';
import HomeContinueWatching from '../components/HomeContinueWatching.jsx';
import HomeFavoriteUpdates from '../components/HomeFavoriteUpdates.jsx';
import HomeEvents from '../components/HomeEvents.jsx';
import HomeChannels from '../components/HomeChannels.jsx';
import HomeMovies from '../components/HomeMovies.jsx';
---

<Layout title="NhanChillTV - Xem Phim & Truyền Hình">
  <MainLayout client:load>
    <HeroBanner client:load />

    <div class="bg-[#070707] px-4 py-10 pb-32 md:px-12 md:py-12">
      <div class="mx-auto flex max-w-[1600px] flex-col gap-12">
        <section class="grid items-start gap-6">
          <WorldCupTodayWidget client:only="react" />
          <div class="grid min-w-0 gap-8 xl:grid-cols-2">
            <HomeContinueWatching client:only="react" />
            <HomeFavoriteUpdates client:only="react" />
          </div>
        </section>

        <section>
          <div class="mb-5 flex items-center justify-between gap-4 md:mb-6">
            <div class="min-w-0">
              <p class="text-xs font-black uppercase tracking-[0.18em] text-[#ED2C25]">Live</p>
              <h2 class="mt-1 text-2xl font-black text-white md:text-4xl">Sự kiện trực tiếp</h2>
            </div>
            <a href="/events/" class="shrink-0 rounded-md bg-[#ED2C25] px-4 py-2 text-sm font-bold text-white transition-colors hover:bg-red-700 md:px-5">Xem tất cả</a>
          </div>
          <HomeEvents client:only="react" />
        </section>

        <section>
          <div class="mb-5 flex items-center justify-between gap-4 md:mb-6">
            <div class="min-w-0">
              <p class="text-xs font-black uppercase tracking-[0.18em] text-[#ED2C25]">TV</p>
              <h2 class="mt-1 text-2xl font-black text-white md:text-4xl">Truyền hình trực tiếp</h2>
            </div>
            <a href="/tv/" class="shrink-0 rounded-md bg-white/10 px-4 py-2 text-sm font-bold text-white/75 transition-colors hover:bg-white/15 hover:text-white md:px-5">Mở TV</a>
          </div>
          <HomeChannels client:only="react" />
        </section>

        <section>
          <div class="mb-5 flex items-center justify-between gap-4 md:mb-6">
            <div class="min-w-0">
              <p class="text-xs font-black uppercase tracking-[0.18em] text-[#ED2C25]">Xem Phim</p>
              <h2 class="mt-1 text-2xl font-black text-white md:text-4xl">Phim mới cập nhật</h2>
            </div>
            <a href="/movies/" class="shrink-0 rounded-md bg-white/10 px-4 py-2 text-sm font-bold text-white/75 transition-colors hover:bg-white/15 hover:text-white md:px-5">Kho phim</a>
          </div>
          <HomeMovies client:only="react" />
        </section>
      </div>
    </div>
  </MainLayout>
</Layout>
