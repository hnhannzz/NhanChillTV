---
import Layout from '../layouts/Layout.astro';
import MainLayout from '../components/MainLayout.jsx';
---

<Layout title="Sự kiện - NhanChillTV">
  <MainLayout client:load>
    <div class="pt-4 md:pt-6 px-4 md:px-8 pb-8 max-w-[1600px] mx-auto text-center mt-4 md:mt-8">
      <h1 class="text-4xl font-bold text-white mb-4">Sự kiện Trực tiếp</h1>
      <p class="text-white/60 mb-8">Hiện tại không có sự kiện trực tiếp nào đang diễn ra. Vui lòng quay lại sau!</p>
      
      <div class="max-w-2xl mx-auto bg-[#121212] rounded-2xl border border-white/5 p-8 text-center">
        <div class="w-20 h-20 bg-white/5 rounded-full flex items-center justify-center mx-auto mb-6">
          <svg xmlns="http://www.w3.org/-svg" width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-white/40"><rect x="3" y="4" width="18" height="18" rx="2" ry="2"></rect><line x1="16" y1="2" x2="16" y2="6"></line><line x1="8" y1="2" x2="8" y2="6"></line><line x1="3" y1="10" x2="21" y2="10"></line></svg>
        </div>
        <h2 class="text-xl font-bold text-white mb-2">Lịch sự kiện sắp tới</h2>
        <p class="text-white/50 text-sm">Các trận bóng đá, sự kiện eSports và liveshow sẽ được cập nhật tại đây.</p>
      </div>
    </div>
  </MainLayout>
</Layout>
