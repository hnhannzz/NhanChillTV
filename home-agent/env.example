NHANCHILL_API_BASE=https://tv.nhanchill.lol/api
HOME_AGENT_TOKEN=change-this-long-random-token
AGENT_ID=home-s905w

EPG_URL=https://vnepg.site/epg.xml
EPG_INTERVAL_SECONDS=1800
HEALTH_INTERVAL_SECONDS=600
HEARTBEAT_INTERVAL_SECONDS=60
CHANNEL_HEALTH_LIMIT=80
CHANNEL_HEALTH_GROUPS=TV360,VTVcab
BACKUP_INTERVAL_SECONDS=86400
BACKUP_KEEP=7
BACKUP_DIR=/opt/nhanchill-home-agent/backups

# Optional local manifest relay. Keep disabled unless you expose it by VPN/tunnel.
RELAY_PORT=0
RELAY_ALLOW_HOSTS=vnepg.site
RELAY_MAX_BYTES=2097152
